{
  "version": 2,
  "github": {
    "enabled": false
  },
  "builds": [
    {
      "src": "api/webhook.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/modules/**",
          "api/handlers/**",
          "api/utils/**",
          "api/data/**",
          "accupass_cache.json",
          "restaurant_cache.json",
          "surprise_cache.json"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/warm_cache",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/parking_worker",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/parking_debug",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/push_test",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/tdx_test",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/diag",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/morning_test",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/stats",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/debug_routes",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/richmenu_info",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/setup_richmenu",
      "dest": "api/webhook.py"
    }
  ]
}
