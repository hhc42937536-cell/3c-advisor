{
  "version": 2,
  "builds": [
    {
      "src": "api/webhook.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "modules/**",
          "utils/**",
          "data/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/warm_cache",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/parking_worker",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/parking_debug",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/push_test",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/tdx_test",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/diag",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/morning_test",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/stats",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/debug_routes",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/richmenu_info",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/setup_richmenu",
      "dest": "api/webhook.py"
    }
  ]
}
